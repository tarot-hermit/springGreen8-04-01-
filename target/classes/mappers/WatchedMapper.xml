<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.spring.springGreen8.dao.WatchedDAO">

    <resultMap id="watchedResultMap" type="com.spring.springGreen8.vo.WatchedVO">
        <id     property="watchedId" column="watched_id"/>
        <result property="mid"       column="mid"/>
        <result property="movieId"   column="movie_id"/>
        <result property="regDate"   column="reg_date"/>
    </resultMap>

    <!-- 봤어요 추가 (중복 시 무시) -->
    <insert id="insertWatched">
        INSERT IGNORE INTO watched (mid, movie_id)
        VALUES (#{mid}, #{movieId})
    </insert>

    <!-- 봤어요 취소 -->
    <delete id="deleteWatched">
        DELETE FROM watched
        WHERE mid = #{mid}
          AND movie_id = #{movieId}
    </delete>

    <!-- 봤어요 여부 확인 -->
    <select id="checkWatched" resultType="int">
        SELECT COUNT(*)
        FROM watched
        WHERE mid = #{mid}
          AND movie_id = #{movieId}
    </select>

    <!-- 내 봤어요 목록 -->
    <select id="selectMyWatched" resultMap="watchedResultMap">
        SELECT watched_id, mid, movie_id, reg_date
        FROM watched
        WHERE mid = #{mid}
        ORDER BY reg_date DESC
    </select>

</mapper>
