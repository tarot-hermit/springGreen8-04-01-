<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.spring.springGreen8.dao.AdminDAO">

    <!-- ============================================================
         ResultMap — users 테이블 컬럼 → UserVO 필드명 매핑
    ============================================================ -->
    <resultMap id="userResultMap" type="com.spring.springGreen8.vo.UserVO">
        <id     property="userNo"      column="user_no"/>
        <result property="userId"      column="user_id"/>
        <result property="userName"    column="user_name"/>
        <result property="userEmail"   column="user_email"/>
        <result property="userImg"     column="user_img"/>
        <result property="userBio"     column="user_bio"/>
        <result property="userRole"    column="user_role"/>
        <result property="userAddr1"   column="user_addr1"/>
        <result property="userAddr2"   column="user_addr2"/>
        <result property="userZipcode" column="user_zipcode"/>
        <result property="joinDate"    column="join_date"/>
    </resultMap>

    <!-- ============================================================
         대시보드 통계
    ============================================================ -->
    <select id="getDashboardStats" resultType="java.util.HashMap">
	    SELECT
	        (SELECT COUNT(*) FROM users)                           AS userCnt,
	        (SELECT COUNT(*) FROM review)                          AS reviewCnt,
	        (SELECT COUNT(*) FROM comment)                         AS commentCnt,
	        (SELECT COUNT(*) FROM watchlist)                       AS watchCnt,
	        (SELECT COUNT(*) FROM report WHERE status = 'PENDING') AS pendingReportCnt
	</select>

    <!-- ============================================================
         회원 전체 목록
    ============================================================ -->
    <select id="getAllUsers" resultMap="userResultMap">
	    SELECT user_no, user_id, user_name, user_email,
	           user_img, user_role, join_date
	    FROM users
	    ORDER BY join_date DESC
	</select>

    <!-- ============================================================
         회원 등급 변경 (userNo 기반)
    ============================================================ -->
    <update id="updateUserRole">
        UPDATE users
        SET user_role = #{userRole}
        WHERE user_no = #{userNo}
    </update>

    <!-- ============================================================
         회원 강제 탈퇴 (물리 삭제 — 필요시 논리 삭제로 변경)
    ============================================================ -->
    <delete id="deleteUser">
        DELETE FROM users
        WHERE user_no = #{userNo}
    </delete>

    <!-- ============================================================
         리뷰 전체 목록
         ReviewVO 필드: reviewId, movieId, movieTitle, mid,
                        rating, content, likeCnt, regDate
    ============================================================ -->
    <select id="getAllReviews" resultType="com.spring.springGreen8.vo.ReviewVO">
	    SELECT
	        r.review_no  AS reviewNo,
	        r.movie_no   AS movieNo,
	        r.user_no    AS userNo,
	        r.rating,
	        r.content,
	        r.reg_date   AS regDate,
	        (SELECT COUNT(*) FROM review_like rl
	         WHERE rl.review_no = r.review_no) AS likeCnt
	    FROM review r
	    ORDER BY r.reg_date DESC
	</select>

    <!-- ============================================================
         리뷰 삭제 (물리 삭제)
    ============================================================ -->
    <delete id="deleteReview">
	    DELETE FROM review
	    WHERE review_no = #{reviewId}
	</delete>

    <!-- ============================================================
         신고 목록 (status 필터링 가능)
    ============================================================ -->
    <select id="getAllReports" resultType="com.spring.springGreen8.vo.ReportVO">
        SELECT
            report_id    AS reportId,
            reporter_mid AS reporterMid,
            target_type  AS targetType,
            target_id    AS targetId,
            reason,
            status,
            reg_date     AS regDate
        FROM report
        ORDER BY reg_date DESC
    </select>

    <!-- ============================================================
         신고 상태 변경 (PENDING → PROCESSED | REJECTED)
    ============================================================ -->
    <update id="updateReportStatus">
        UPDATE report
        SET status = #{status}
        WHERE report_id = #{reportId}
    </update>

</mapper>
